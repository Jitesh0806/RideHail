{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": false,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@services/*": ["src/services/*"],
      "@store/*": ["src/store/*"],
      "@screens/*": ["src/screens/*"],
      "@hooks/*": ["src/hooks/*"],
      "@types/*": ["src/types/*"],
      "@navigation/*": ["src/navigation/*"],
      "@components/*": ["src/components/*"]
    }
  }
}
