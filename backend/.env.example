# App
NODE_ENV=development
PORT=3000
APP_NAME=RideHail

# Database (AWS RDS PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ridehail
DB_PASSWORD=your_password
DB_NAME=ridehail_db
DB_SSL=false

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# AWS Cognito
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS S3
S3_BUCKET_NAME=ridehail-storage
S3_BUCKET_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# AWS SNS (Notifications)
SNS_REGION=us-east-1
SNS_PLATFORM_APPLICATION_ARN=arn:aws:sns:us-east-1:...

# Redis (AWS ElastiCache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Driver Radius Settings (km)
INITIAL_DRIVER_SEARCH_RADIUS=3
MAX_DRIVER_SEARCH_RADIUS=10
RADIUS_EXPANSION_INTERVAL_MS=120000

# Admin
ADMIN_EMAIL=admin@ridehail.com
ADMIN_PASSWORD=secure_admin_password
